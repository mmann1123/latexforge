rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Legacy user profile docs
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Dynamic email allowlist for invited collaborators
    // Readable without auth (checked during registration before user exists)
    // Only the admin can write directly
    match /config/allowedEmails {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'mmann1123@gmail.com';
    }

    // Projects: owner or collaborator
    match /projects/{projectId} {
      function isOwner() {
        return request.auth.uid == resource.data.ownerId;
      }
      function isEditor() {
        return resource.data.collaborators[request.auth.uid] == 'editor';
      }
      function canRead() {
        return isOwner() || (request.auth.uid in resource.data.collaborators);
      }
      function canWrite() {
        return isOwner() || isEditor();
      }

      // For subcollection rules: look up the parent project doc
      function projectData() {
        return get(/databases/$(database)/documents/projects/$(projectId)).data;
      }
      function parentCanRead() {
        return request.auth.uid == projectData().ownerId
            || request.auth.uid in projectData().collaborators;
      }
      function parentCanWrite() {
        return request.auth.uid == projectData().ownerId
            || projectData().collaborators[request.auth.uid] == 'editor';
      }

      allow read: if request.auth != null && canRead();
      // On create: must set ownerId to self
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      // Allow update if user canWrite OR if they are accepting an invitation
      // (adding only their own uid to the collaborators map)
      allow update: if request.auth != null
                    && (canWrite()
                        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['collaborators'])
                            && request.resource.data.collaborators[request.auth.uid] in ['editor', 'viewer']));
      allow delete: if request.auth != null && isOwner();

      // Files subcollection
      match /files/{fileId} {
        allow read: if request.auth != null && parentCanRead();
        allow write: if request.auth != null && parentCanWrite();
      }

      // Comments subcollection (nested under files)
      match /files/{fileId}/comments/{commentId} {
        allow read: if request.auth != null && parentCanRead();
        allow create: if request.auth != null && parentCanWrite();
        allow update: if request.auth != null && parentCanWrite();
      }

      // Yjs updates subcollection
      match /yjs/{fileId} {
        allow read: if request.auth != null && parentCanRead();
        allow write: if request.auth != null && parentCanWrite();
      }

      // Presence subcollection — only collaborators can read/write
      match /presence/{presenceId} {
        allow read: if request.auth != null && parentCanRead();
        allow create, update: if request.auth != null && parentCanRead();
        allow delete: if request.auth != null;
      }
    }

    // Mail collection for Firebase Trigger Email extension
    // Authenticated users can create; only the extension service account reads/processes
    match /mail/{mailId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Invitations
    match /invitations/{invitationId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
                  && (resource.data.invitedEmail == request.auth.token.email
                  || resource.data.invitedBy == request.auth.uid);
      allow update: if request.auth != null
                    && (resource.data.invitedEmail == request.auth.token.email
                    || resource.data.invitedBy == request.auth.uid);
      allow delete: if request.auth != null
                    && resource.data.invitedBy == request.auth.uid;
    }
  }
}
